# Docker / docker compose defaults

BACKEND_PORT=8000
FRONTEND_PORT=3000
DOCKER_BACKEND_BIND_PORT=8000
DOCKER_FRONTEND_BIND_PORT=80
DOCKER_SAM3_BIND_PORT=8021
DOCKER_HOST_NETWORK=0
DOCKER_APP_WORKERS=1
DOCKER_BACKEND_INSTALL_CUDA=0
PYTHON_BASE_IMAGE=python:3.11-slim
NODE_BASE_IMAGE=node:20-alpine
NGINX_BASE_IMAGE=nginx:alpine

# Optional local SAM3 container profile
SAM3_PORT=8021
SAM3_HOME=
SAM3_CHECKPOINT_PATH=
SAM3_BPE_PATH=
SAM3_SERVER_URLS=

# Optional frontend public build args overrides
VITE_API_KEY=
VITE_API_BASE_URL=
VITE_DEFAULT_LLM_API_URL=
VITE_LLM_API_URLS=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
