# ============================================
# 使用说明（Advanced / Fine-grained）
# ============================================
# 如果你只想填很少的 URL / Key，请优先使用：
#   fastapi_app/.env.simple.example
# 当前这个 .env.example 是“细粒度 / 高级模式”示例，保留所有 workflow / model 级别开关。
# 1. 复制本文件为 .env：cp .env.example .env
# 2. 在 .env 中填入真实 key（不要提交 .env 到 git）
# 3. 启动后端后会自动加载 fastapi_app/.env，无需在终端 export
# 4. 配置职责说明：
#    - BACKEND_API_KEY: 保护本项目 FastAPI 接口，前端 VITE_API_KEY 必须与之相同
#    - PAPER2*_MANAGED_API_* / KB*_MANAGED_API_*: Free 模式下各 workflow 的托管文本模型入口
#    - PAPER2*_MANAGED_IMAGE_API_* / KB*_MANAGED_IMAGE_API_*: Free 模式下各 workflow 的托管生图入口
#    - DF_API_URL / DF_API_KEY: 文本托管的全局兼容回退
#    - DF_IMAGE_API_URL / DF_IMAGE_API_KEY: 生图托管的全局兼容回退；若留空，再回退到文本托管
#    - PAPER2DRAWIO_OCR_API_URL / PAPER2DRAWIO_OCR_API_KEY: OCR / Qwen-VL 专用配置
#    - PAPER2DRAWIO_SEGMENT_HINT_* / PAPER2PPT_SEGMENT_HINT_*: 给 SAM3 补充分割提示词的 VLM
#    - PAPER2FIGURE_TO_PPT_FORCE_AI_EDIT: paper2graph 右侧“转 PPT”按钮是否强制走 AI inpainting
#    - PAPER2CITATION_WEBSEARCH_*: 论文引用追踪的可选联网模型增强，用于补作者荣誉/大佬引用统计
#    - COSYVOICE_KEY: 阿里云 CosyVoice 语音合成
#    - LIVEPORTRAIT_KEY: 阿里云 LivePortrait 数字人
#    - SUPABASE_*: 用户登录、文件存储、配额等
# 5. 不要把这些后端业务配置再重复写进 `deploy/profiles/*.env`；
#    `deploy/profiles/*.env` 只保留机器部署参数（端口、python、GPU、模型路径等）。
# ============================================
# API Keys（由 os.getenv 读取，无需在 shell 里 export）
# ============================================
# 前后端内部通信 Key。
# 它只负责“谁可以调用本项目 FastAPI 接口”，不负责第三方云服务鉴权。
# 前端 `frontend-workflow/.env` 中的 VITE_API_KEY 必须与这里完全一致。
BACKEND_API_KEY=your-backend-api-key

# 计费 / 托管模式：
# - paid: 维持原有“用户自己提供业务 API Key”的模式，平台默认不扣点。
# - free: 业务 API Key 全部走后端 .env，前端不再依赖用户填写；右上角点数由 pricing.yaml 控制。
APP_BILLING_MODE=paid

# free 模式下的点数购买 / 兑换码配置。
# POINTS_PURCHASE_URL: 右上角“继续购买”和头像菜单里的外部跳转地址（发卡平台）。
# POINTS_REDEEM_CODE_FILE_*: 不同面额兑换码文件，一行一个 Token；默认指向项目根目录 data/redeem_codes/*.txt。
POINTS_PURCHASE_URL=
POINTS_REDEEM_CODE_FILE_10=./data/redeem_codes/points_10.txt
POINTS_REDEEM_CODE_FILE_50=./data/redeem_codes/points_50.txt
POINTS_REDEEM_CODE_FILE_100=./data/redeem_codes/points_100.txt

# 通用 LLM 网关兼容回退。
# 如果某个 workflow 没有单独配置 PAPER2*_MANAGED_API_* / KB*_MANAGED_API_*，
# Free 模式下才会回退到这组 DF_*。
DF_API_URL=http://123.129.219.111:3000/v1
DF_API_KEY=sk-your-llm-api-key
DF_IMAGE_API_URL=
DF_IMAGE_API_KEY=

# Free 模式下各 workflow 的托管业务模型入口。
# 推荐做法：每个 workflow 都显式配置；这样不会再出现“所有功能都被 DF_* 接管”的问题。
# 文本入口留空时回退到 DF_API_URL / DF_API_KEY。
# 图片入口留空时优先回退到 DF_IMAGE_API_URL / DF_IMAGE_API_KEY，再回退到文本托管入口。
PAPER2ANY_MANAGED_API_URL=
PAPER2ANY_MANAGED_API_KEY=
PAPER2ANY_MANAGED_IMAGE_API_URL=
PAPER2ANY_MANAGED_IMAGE_API_KEY=
PAPER2PPT_MANAGED_API_URL=
PAPER2PPT_MANAGED_API_KEY=
PAPER2PPT_MANAGED_IMAGE_API_URL=
PAPER2PPT_MANAGED_IMAGE_API_KEY=
PPT2POLISH_MANAGED_API_URL=
PPT2POLISH_MANAGED_API_KEY=
PPT2POLISH_MANAGED_IMAGE_API_URL=
PPT2POLISH_MANAGED_IMAGE_API_KEY=
PDF2PPT_MANAGED_API_URL=
PDF2PPT_MANAGED_API_KEY=
PDF2PPT_MANAGED_IMAGE_API_URL=
PDF2PPT_MANAGED_IMAGE_API_KEY=
IMAGE2PPT_MANAGED_API_URL=
IMAGE2PPT_MANAGED_API_KEY=
IMAGE2PPT_MANAGED_IMAGE_API_URL=
IMAGE2PPT_MANAGED_IMAGE_API_KEY=
PAPER2DRAWIO_MANAGED_API_URL=
PAPER2DRAWIO_MANAGED_API_KEY=
PAPER2DRAWIO_MANAGED_IMAGE_API_URL=
PAPER2DRAWIO_MANAGED_IMAGE_API_KEY=
PAPER2POSTER_MANAGED_API_URL=
PAPER2POSTER_MANAGED_API_KEY=
PAPER2POSTER_MANAGED_IMAGE_API_URL=
PAPER2POSTER_MANAGED_IMAGE_API_KEY=
PAPER2VIDEO_MANAGED_API_URL=
PAPER2VIDEO_MANAGED_API_KEY=
PAPER2VIDEO_MANAGED_IMAGE_API_URL=
PAPER2VIDEO_MANAGED_IMAGE_API_KEY=
KB_MANAGED_API_URL=
KB_MANAGED_API_KEY=
KB_MANAGED_IMAGE_API_URL=
KB_MANAGED_IMAGE_API_KEY=
KB_DEEPRESEARCH_MANAGED_API_URL=
KB_DEEPRESEARCH_MANAGED_API_KEY=
KB_DEEPRESEARCH_MANAGED_IMAGE_API_URL=
KB_DEEPRESEARCH_MANAGED_IMAGE_API_KEY=
PAPER2REBUTTAL_MANAGED_API_URL=
PAPER2REBUTTAL_MANAGED_API_KEY=
PAPER2REBUTTAL_MANAGED_IMAGE_API_URL=
PAPER2REBUTTAL_MANAGED_IMAGE_API_KEY=

# 阿里云 DashScope 相关服务
# 这些服务通常可以复用同一个 DashScope Key，也可以按服务拆开配置。
# OCR 兼容模式地址默认如下；如后续切换网关，可只改 URL 不改代码。
PAPER2DRAWIO_OCR_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PAPER2DRAWIO_OCR_API_KEY=your_dashscope_key

# Paper2Drawio 细粒度分割提示专用 VLM。
# 可选；用于先看一遍图，补充 SAM3 的目标词，比通用 DF_* 更稳定时建议单独配置。
# 不填则回退到 DF_API_URL / DF_API_KEY；如果理解型 VLM 失败，再回退 OCR 模型。
PAPER2DRAWIO_SEGMENT_HINT_API_URL=http://your-segment-hint-vlm/v1
PAPER2DRAWIO_SEGMENT_HINT_API_KEY=your_segment_hint_vlm_key
PAPER2DRAWIO_SEGMENT_HINT_VLM_MODEL=gpt-4o
PAPER2DRAWIO_SEGMENT_HINT_TIMEOUT=120

# PDF2PPT / Image2PPT 细粒度分割提示专用 VLM。
# 逻辑与 drawio 相同：先做一次图像理解，为 SAM3 补充更具体的目标词。
# 不填则回退到 DF_API_URL / DF_API_KEY；如果理解型 VLM 失败，再回退 OCR 模型。
PAPER2PPT_SEGMENT_HINT_API_URL=http://your-segment-hint-vlm/v1
PAPER2PPT_SEGMENT_HINT_API_KEY=your_segment_hint_vlm_key
PAPER2PPT_SEGMENT_HINT_VLM_MODEL=gpt-4o
PAPER2PPT_SEGMENT_HINT_TIMEOUT=120

# paper2graph 里“模型结构图生成后再转 PPT”是否强制开启 AI 背景修复。
# 建议保持 true，这样 PreviewSection 右侧“转 PPT”按钮会走 AI inpainting。
PAPER2FIGURE_TO_PPT_FORCE_AI_EDIT=true

# Optional: use a dedicated Python interpreter for paper2video worker.
# If unset, the backend will reuse the current Python / python3 automatically.
PAPER2VIDEO_PYTHON=

# paper2video 游标点位推理。
# 默认优先尝试本地 UI-TARS 子进程 worker；不常驻内存，按请求拉起，处理完即退出。
# 推荐做法：
# - base 后端环境不装 ui-tars
# - 单独准备一个能跑 UI-TARS 的 Python / conda 环境
# - 通过 PAPER2VIDEO_CURSOR_LOCAL_PYTHON 指向那个解释器
# 若未配置本地 worker，则自动回退到远端 VLM；再不满足时降级为中心点，不阻塞视频生成。
PAPER2VIDEO_CURSOR_API_URL=
PAPER2VIDEO_CURSOR_API_KEY=
PAPER2VIDEO_CURSOR_VLM_MODEL=gpt-4o-2024-11-20
PAPER2VIDEO_CURSOR_TIMEOUT=120
PAPER2VIDEO_CURSOR_VLM_PARALLELISM=4
PAPER2VIDEO_CURSOR_LOCAL_MODEL_PATH=
PAPER2VIDEO_CURSOR_LOCAL_ENABLED=auto
PAPER2VIDEO_CURSOR_GPUS=
PAPER2VIDEO_CURSOR_LOCAL_PYTHON=
PAPER2VIDEO_CURSOR_LOCAL_EXTRA_PYTHONPATH=
PAPER2VIDEO_CURSOR_LOCAL_TIMEOUT=1800
PAPER2VIDEO_CURSOR_LOCAL_MAX_NEW_TOKENS=64
PAPER2VIDEO_CURSOR_LOCAL_ATTN_IMPL=eager
PAPER2VIDEO_CURSOR_LOCAL_ALLOC_CONF=expandable_segments:True

# paper2video 音频 / 字幕 / 数字人。
# 当前默认部署链路是：
# - TTS: CosyVoice API
# - Talking head: LivePortrait API
# 所以下面这些本地参数默认都可以保持关闭或留空。
PAPER2VIDEO_TTS_PARALLELISM=3
PAPER2VIDEO_VIDEO_RENDER_THREADS=12
PAPER2VIDEO_SUBTITLE_FONT_PATH=
# Only for .ttc/.otc font collections; leave empty to auto-try 0,1,2,3.
PAPER2VIDEO_SUBTITLE_FONT_INDEX=

# 本地 F5-TTS / WhisperX 仅在显式打开时使用；默认部署不需要。
PAPER2VIDEO_ENABLE_LOCAL_TTS=false
PAPER2VIDEO_LOCAL_TTS_GPU_IDS=
PAPER2VIDEO_LOCAL_TTS_PYTHON=
PAPER2VIDEO_LOCAL_TTS_EXTRA_PYTHONPATH=
PAPER2VIDEO_WHISPERX_MODEL=large-v2
PAPER2VIDEO_WHISPERX_DEVICE_ID=

# 云 / 本地 talking-head 额外配置。
PAPER2VIDEO_TALKING_PARALLELISM=4
PAPER2VIDEO_ECHOMIMIC_API_URL=
PAPER2VIDEO_ECHOMIMIC_API_PARALLELISM=8
PAPER2VIDEO_ECHOMIMIC_TIMEOUT_SECONDS=900
PAPER2VIDEO_TALKING_LOCAL_PYTHON=
PAPER2VIDEO_TALKING_LOCAL_GPUS=
PAPER2VIDEO_ECHOMIMIC_CONFIG_PATH=
PAPER2VIDEO_ECHOMIMIC_SCRIPT_PATH=
PAPER2VIDEO_ECHOMIMIC_WORKDIR=
PAPER2VIDEO_HALLO2_CONFIG_PATH=
PAPER2VIDEO_HALLO2_SCRIPT_PATH=
PAPER2VIDEO_HALLO2_WORKDIR=

# MinerU 解析服务
# 若配置 MINERU_API_KEY，则优先走官方远端 API；
# 若不配置，则继续回退到本地 MINERU_PORT。
MINERU_API_BASE_URL=https://mineru.net/api/v4
MINERU_API_KEY=your_mineru_api_key
MINERU_API_MODEL_VERSION=vlm
MINERU_API_POLL_INTERVAL_SECONDS=5
MINERU_API_TIMEOUT_SECONDS=900
MINERU_PORT=8010

# Paper2Citation 可选联网模型增强
# 用于补作者本人荣誉标签，以及“哪些带 Fellow / 院士等荣誉的作者引用了目标作者/论文”。
# 请在本地 .env 填真实值，不要把真实 Key 提交到 git。
PAPER2CITATION_WEBSEARCH_ENABLED=false
PAPER2CITATION_WEBSEARCH_API_URL=https://api.ikuncode.cc/
PAPER2CITATION_WEBSEARCH_API_KEY=your_websearch_model_key
# Example: claude-haiku-4-5-20251001-thinking-all / claude-haiku-4-5-20251001-all
PAPER2CITATION_WEBSEARCH_MODEL=gpt-5.4
# Comma-separated fallback models, tried after the primary model fails or times out.
PAPER2CITATION_WEBSEARCH_FALLBACK_MODELS=gpt-5.2
PAPER2CITATION_WEBSEARCH_TOOL=web_search_preview
PAPER2CITATION_WEBSEARCH_TIMEOUT_SECONDS=30
PAPER2CITATION_WEBSEARCH_DISABLE_SECONDS=600
PAPER2CITATION_WEBSEARCH_MAX_AUTHORS=60
PAPER2CITATION_WEBSEARCH_BATCH_SIZE=6
PAPER2CITATION_WEBSEARCH_SOURCE_CONCURRENCY=12
PAPER2CITATION_WEBSEARCH_MAX_OUTPUT_TOKENS=1200

# 云语音 CosyVoice（阿里云 DashScope）
# 仅 paper2video TTS 使用。
COSYVOICE_KEY=your_cosyvoice_key

# 云数字人 LivePortrait（阿里云 DashScope）
# 仅 paper2video 数字人视频生成 / 人脸检测使用。
LIVEPORTRAIT_KEY=your_liveportrait_key

# ============================================
# Supabase Configuration (Optional)
# ============================================
# 用于用户登录、JWT、历史文件、配额等；不用 Supabase 时可留空。
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# free 模式下知识库 Deep Research(web) 的默认搜索配置。
# 如果不做联网检索，可留空。
DEFAULT_SEARCH_API_KEY=
DEFAULT_GOOGLE_CSE_ID=

# 可选：仅在需要自行验签 Supabase JWT 或与外部中间件对齐时使用。
# 当前后端主要通过 Supabase SDK / 公钥接口完成鉴权，不依赖它也可运行。
SUPABASE_JWT_SECRET=

# 手工直启后端时可填写一个或多个 SAM3 服务地址，逗号分隔。
# 通过 `deploy/start.sh` 启动时，通常会由 `logs/model_servers.env` 自动覆盖。
SAM3_SERVER_URLS=http://127.0.0.1:8021,http://127.0.0.1:8022

# ============================================
# Model Configuration - Layer 1: Base Models
# ============================================
# Define all available model names. These are referenced by workflow and role configurations.
MODEL_GPT_4O=gpt-4o
MODEL_GPT_5_1=gpt-5.1
MODEL_CLAUDE_HAIKU=claude-haiku-4-5-20251001
MODEL_GEMINI_PRO_IMAGE=gemini-3-pro-image-preview
MODEL_GEMINI_FLASH_IMAGE=gemini-2.5-flash-image
MODEL_GEMINI_FLASH=gemini-2.5-flash
MODEL_QWEN_VL_OCR=qwen-vl-ocr-2025-11-20

# Default LLM API URL (internal service)
DEFAULT_LLM_API_URL=http://123.129.219.111:3000/v1/
LLM_VERIFY_TIMEOUT_SECONDS=25
LLM_VERIFY_MAX_TOKENS=32

# ============================================
# Model Configuration - Layer 2: Workflow-level Defaults
# ============================================
# Default models for each workflow. Override these to change workflow-wide defaults.

# Paper2PPT Workflow
PAPER2PPT_DEFAULT_MODEL=gpt-5.4
PAPER2PPT_DEFAULT_IMAGE_MODEL=gemini-3-pro-image-preview

# PDF2PPT Workflow
PDF2PPT_DEFAULT_MODEL=gpt-4o
PDF2PPT_DEFAULT_IMAGE_MODEL=gemini-2.5-flash-image

# PDF2PPT / Image2PPT visual cleanup
# Controls per-icon RMBG background removal after SAM3.
# auto: use RMBG_DEVICE / accelerator auto-detection
# cpu: force CPU
# cuda / cuda:N: force accelerator device
# off: skip icon background removal entirely
PAPER2PPT_ICON_BG_REMOVE_MODE=auto
RMBG_DEVICE=auto

# Paper2Figure Workflow
PAPER2FIGURE_DEFAULT_MODEL=gpt-4o
PAPER2FIGURE_DEFAULT_IMAGE_MODEL=gemini-3-pro-image-preview

# Paper2Video Workflow
PAPER2VIDEO_DEFAULT_MODEL=gpt-4o

# Paper2Drawio Workflow
PAPER2DRAWIO_DEFAULT_MODEL=gpt-5.4
PAPER2DRAWIO_VLM_MODEL=qwen-vl-ocr-2025-11-20
PAPER2DRAWIO_ENABLE_VLM_VALIDATION=false
PAPER2DRAWIO_SAM3_CHECKPOINT_PATH=./models/sam3/sam3.pt
PAPER2DRAWIO_SAM3_BPE_PATH=./models/sam3/bpe_simple_vocab_16e6.txt.gz

# Knowledge Base
KB_EMBEDDING_MODEL=gemini-2.5-flash
KB_CHAT_MODEL=gpt-4o

# ============================================
# Model Configuration - Layer 3: Role-level (Fine-grained Control)
# ============================================
# Override specific roles within workflows for maximum control.

# Paper2PPT Roles
PAPER2PPT_OUTLINE_MODEL=gpt-5.1              # Outline generation
PAPER2PPT_CONTENT_MODEL=gpt-5.4              # Content generation
PAPER2PPT_IMAGE_GEN_MODEL=gemini-3-pro-image-preview  # Image generation
PAPER2PPT_VLM_MODEL=gpt-5.4                  # Vision-language model (review)
PAPER2PPT_CHART_MODEL=gpt-4o                 # Chart generation
PAPER2PPT_DESC_MODEL=gpt-5.1                 # Figure description
PAPER2PPT_TECHNICAL_MODEL=claude-haiku-4-5-20251001  # Technical details

# Paper2Figure Roles
PAPER2FIGURE_TEXT_MODEL=gpt-4o
PAPER2FIGURE_IMAGE_MODEL=gemini-3-pro-image-preview
PAPER2FIGURE_VLM_MODEL=qwen-vl-ocr-2025-11-20
PAPER2FIGURE_CHART_MODEL=gpt-4o
PAPER2FIGURE_DESC_MODEL=gpt-5.1
PAPER2FIGURE_TECHNICAL_MODEL=gpt-5.4
