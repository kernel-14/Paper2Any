# ===========================================
# Internal API Configuration
# ===========================================
# 本文件只负责前端可见配置。
# 不要把后端业务 key（例如 OCR / MinerU / Supabase service role / 各类第三方服务密钥）
# 再重复写进 deploy profile。
# 前端调用本项目 FastAPI 时携带的内部鉴权 key。
# 必须与 `fastapi_app/.env` 中的 BACKEND_API_KEY 完全一致。
# 它不是用户登录 key，也不是 OpenAI / DashScope 之类第三方服务 key。
VITE_API_KEY=your-backend-api-key

# Frontend -> backend base URL.
# 本地用 `npm run dev` + Vite 代理时通常保持为空即可；
# 如果以后改成静态部署，再填完整后端地址，例如 `http://127.0.0.1:8000`。
VITE_API_BASE_URL=

# ===========================================
# LLM Provider Configuration
# ===========================================
# 这些只是前端表单里的默认展示值，不是后端强制配置。
# 用户在页面上通常可以临时覆盖。
# 如果后端 APP_BILLING_MODE=free，则这里仍然只作为前端默认展示值，
# 真正生效的业务 API Key / URL 由后端 `fastapi_app/.env` 托管。

# Default LLM API URL (shown in "API URL" input field)
VITE_DEFAULT_LLM_API_URL=https://api.apiyi.com/v1

# List of available LLM API URLs (comma separated)
VITE_LLM_API_URLS=https://api.apiyi.com/v1,http://b.apiyi.com:16888/v1,http://123.129.219.111:3000/v1,https://ai.comfly.chat/v1

# Default LLM model name for verification
VITE_DEFAULT_LLM_MODEL=deepseek-v3.2
VITE_LLM_VERIFY_TIMEOUT_MS=30000

# ===========================================
# Default Model Configuration
# ===========================================
# Default models used by different sub-pages.
# These only set initial values; users can still override in the UI.

# Paper2Figure (2figure) - per graph type (comma separated)
VITE_PAPER2FIGURE_MODEL_MODEL_ARCH=gemini-3-pro-image-preview,gemini-2.5-flash-image-preview
VITE_PAPER2FIGURE_MODEL_EXP_DATA=gemini-3-pro-image-preview,gemini-2.5-flash-image-preview
VITE_PAPER2FIGURE_MODEL_TECH_ROUTE=gpt-5.4,gpt-5.2

# Paper2PPT (2ppt) (comma separated)
VITE_PAPER2PPT_MODEL=gpt-5.4,gpt-5.1,gpt-5.2,gemini-3-pro-preview
VITE_PAPER2PPT_GEN_FIG_MODEL=gemini-3-pro-image-preview,gemini-2.5-flash-image

# PDF2PPT / Image2PPT (comma separated)
VITE_PDF2PPT_GEN_FIG_MODEL=gemini-3-pro-image-preview
VITE_IMAGE2PPT_GEN_FIG_MODEL=gemini-3-pro-image-preview
VITE_IMAGE2PPT_USE_AI_EDIT_DEFAULT=false

# PPT2Polish (comma separated)
VITE_PPT2POLISH_MODEL=gpt-5.1,gpt-5.2,gemini-3-pro-preview
VITE_PPT2POLISH_GEN_FIG_MODEL=gemini-3-pro-image-preview

# Paper2Drawio / Image2Drawio (comma separated)
VITE_PAPER2DRAWIO_MODEL=gpt-5.4,gpt-5.2
VITE_PAPER2DRAWIO_IMAGE_MODEL=gemini-3-pro-image-preview
VITE_IMAGE2DRAWIO_GEN_FIG_MODEL=gemini-3-pro-image-preview
VITE_IMAGE2DRAWIO_VLM_MODEL=qwen-vl-ocr-2025-11-20

# Paper2Rebuttal (comma separated)
VITE_PAPER2REBUTTAL_MODEL=deepseek-v3.1,kimi-k2-128k

# ===========================================
# Supabase Configuration (Optional)
# ===========================================
# 填这两个即可启用前端登录态、配额展示和云端历史。
# Get values from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
